# BenchFirst go-live env contract (i7). Copy to `.env` and fill in when creds land.
# `.env` is gitignored — NEVER commit real secrets. Load with:  set -a; . ./.env; set +a
#
# Everything here is OPTIONAL: with nothing set, the loop/demo run fully offline
# (local JSON memory, deterministic picker, ungated writer). Each var switches one
# leg from offline-fallback to the live sponsor.

# ── AWS (S3 scar file + Bedrock picker) ──────────────────────────────────────
# Scoped credentials. For the WRITER identity, grant ONLY s3:PutObject/GetObject
# on the one bucket/key (that scoping is what makes "opinion can't reach S3" real).
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=              # if using temporary/STS creds

# S3 scar file (i2). Set the bucket to switch memory from local JSON to S3.
# BENCHFIRST_S3_BUCKET=benchfirst-scar-<unique>
BENCHFIRST_S3_KEY=benchfirst/memory.json

# Bedrock picker (i1). Set the model id to let Claude propose candidate order;
# unset = deterministic offline fallback. Enable model access in the Bedrock console
# and use the exact (often us.-prefixed cross-region inference-profile) id it shows.
# BENCHFIRST_BEDROCK_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Verdict writer + Pomerium (i3/i4/i5) ─────────────────────────────────────
# Point the loop at the deployed, Pomerium-fronted writer. Unset = in-process writer.
# BENCHFIRST_WRITER_URL=https://verdict.<your-domain>

# Turns the writer's identity backstop ON (fail-closed). Must equal the identity
# Pomerium's allow-policy admits. Set INSIDE the writer container/deploy, not here.
# BENCHFIRST_VERDICT_IDENTITY=verdict-runner@<your-domain>
# BENCHFIRST_WRITER_HOST=0.0.0.0  # container bind (default 127.0.0.1 locally)
# BENCHFIRST_WRITER_PORT=8787

# ── Pomerium deploy secrets (used by pomerium/config.yaml via envsubst) ──────
# BENCHFIRST_DOMAIN=<your-domain>
# POMERIUM_COOKIE_SECRET=         # head -c32 /dev/urandom | base64
# POMERIUM_SHARED_SECRET=         # head -c32 /dev/urandom | base64
# BENCHFIRST_IDP_PROVIDER=        # e.g. google / oidc
# BENCHFIRST_IDP_CLIENT_ID=
# BENCHFIRST_IDP_CLIENT_SECRET=
